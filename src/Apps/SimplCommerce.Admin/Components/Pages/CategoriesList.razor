@page "/categories"
@rendermode RenderMode.InteractiveServer
@inject IAdminCatalogApi Catalog
@inject ISnackbar Snack

<PageTitle>Categories — Admin</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">Categories</MudText>

<MudPaper Class="pa-4">
    <EditForm Model="_input" OnValidSubmit="Create" FormName="newCategory">
        <DataAnnotationsValidator />
        <MudStack Row="true" AlignItems="AlignItems.End">
            <MudTextField @bind-Value="_input.Name" Label="Name" Required="true" />
            <MudTextField @bind-Value="_input.Slug" Label="Slug" Required="true" />
            <MudNumericField T="int" @bind-Value="_input.DisplayOrder" Label="Order" Min="0" Max="9999" />
            <MudButton ButtonType="ButtonType.Submit" Color="Color.Primary" Variant="Variant.Filled">Add</MudButton>
        </MudStack>
    </EditForm>
    <MudDivider Class="my-3" />

    @if (_categories is null)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <MudTable T="CategoryItem" Items="_categories" Hover="true" Dense="true">
            <HeaderContent>
                <MudTh>ID</MudTh>
                <MudTh>Name</MudTh>
                <MudTh>Slug</MudTh>
                <MudTh>Parent</MudTh>
                <MudTh>Order</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Id</MudTd>
                <MudTd>@context.Name</MudTd>
                <MudTd>@context.Slug</MudTd>
                <MudTd>@(context.ParentId?.ToString() ?? "—")</MudTd>
                <MudTd>@context.DisplayOrder</MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    private IReadOnlyList<CategoryItem>? _categories;
    private NewCategoryInput _input = new();

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        _categories = await Catalog.ListCategoriesAsync();
        StateHasChanged();
    }

    private async Task Create()
    {
        var resp = await Catalog.CreateCategoryAsync(new CategoryInput(_input.Name, _input.Slug, null, _input.DisplayOrder, null));
        if (resp.IsSuccessStatusCode)
        {
            Snack.Add("Category added.", Severity.Success);
            _input = new();
            await Reload();
        }
        else
        {
            Snack.Add("Create failed — HTTP " + (int)resp.StatusCode, Severity.Error);
        }
    }

    public sealed class NewCategoryInput
    {
        [System.ComponentModel.DataAnnotations.Required] public string Name { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required] public string Slug { get; set; } = string.Empty;
        public int DisplayOrder { get; set; }
    }
}
