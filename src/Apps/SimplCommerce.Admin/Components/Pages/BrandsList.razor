@page "/brands"
@rendermode RenderMode.InteractiveServer
@inject IAdminCatalogApi Catalog
@inject ISnackbar Snack

<PageTitle>Brands — Admin</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">Brands</MudText>

<MudPaper Class="pa-4">
    <EditForm Model="_input" OnValidSubmit="Create" FormName="newBrand">
        <DataAnnotationsValidator />
        <MudStack Row="true" AlignItems="AlignItems.End">
            <MudTextField @bind-Value="_input.Name" Label="Name" Required="true" />
            <MudTextField @bind-Value="_input.Slug" Label="Slug" Required="true" />
            <MudCheckBox T="bool" @bind-Value="_input.IsPublished" Label="Published" />
            <MudButton ButtonType="ButtonType.Submit" Color="Color.Primary" Variant="Variant.Filled">Add</MudButton>
        </MudStack>
    </EditForm>
    <MudDivider Class="my-3" />

    @if (_brands is null)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <MudTable T="BrandItem" Items="_brands" Hover="true" Dense="true">
            <HeaderContent>
                <MudTh>ID</MudTh><MudTh>Name</MudTh><MudTh>Slug</MudTh><MudTh>Published</MudTh><MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Id</MudTd>
                <MudTd>@context.Name</MudTd>
                <MudTd>@context.Slug</MudTd>
                <MudTd>@(context.IsPublished ? "✓" : "—")</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => Delete(context.Id))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    private IReadOnlyList<BrandItem>? _brands;
    private NewBrandInput _input = new();

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload() { _brands = await Catalog.ListBrandsAsync(); StateHasChanged(); }

    private async Task Create()
    {
        var resp = await Catalog.CreateBrandAsync(new BrandInput(_input.Name, _input.Slug, _input.IsPublished));
        if (resp.IsSuccessStatusCode)
        {
            Snack.Add("Brand added.", Severity.Success);
            _input = new();
            await Reload();
        }
        else { Snack.Add("Create failed — HTTP " + (int)resp.StatusCode, Severity.Error); }
    }

    private async Task Delete(long id)
    {
        var resp = await Catalog.DeleteBrandAsync(id);
        if (resp.IsSuccessStatusCode) { Snack.Add("Brand deleted.", Severity.Success); await Reload(); }
        else { Snack.Add("Delete failed.", Severity.Error); }
    }

    public sealed class NewBrandInput
    {
        [System.ComponentModel.DataAnnotations.Required] public string Name { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required] public string Slug { get; set; } = string.Empty;
        public bool IsPublished { get; set; } = true;
    }
}
