@page "/activity-log"
@rendermode RenderMode.InteractiveServer
@inject IAdminActivityApi Activity

<PageTitle>Activity log — Admin</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">Activity log</MudText>

<MudPaper Class="pa-4">
    @if (_page is null)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <MudTable T="AdminActivityItem" Items="_page.Items" Hover="true" Dense="true">
            <HeaderContent>
                <MudTh>ID</MudTh><MudTh>Type</MudTh><MudTh>User</MudTh>
                <MudTh>Entity</MudTh><MudTh>When</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Id</MudTd>
                <MudTd>@context.ActivityTypeId</MudTd>
                <MudTd>@context.UserId</MudTd>
                <MudTd>@context.EntityTypeId #@context.EntityId</MudTd>
                <MudTd>@context.CreatedOn.ToLocalTime().ToString("g")</MudTd>
            </RowTemplate>
        </MudTable>
        <MudPagination Count="@((int)Math.Ceiling(_page.Total / (double)_pageSize))"
                       Selected="_pageNum" SelectedChanged="OnPageChange" Class="mt-3" />
    }
</MudPaper>

@code {
    private int _pageNum = 1;
    private const int _pageSize = 50;
    private AdminActivityPage? _page;

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload() { _page = await Activity.ListAsync(_pageNum, _pageSize); StateHasChanged(); }
    private async Task OnPageChange(int p) { _pageNum = p; await Reload(); }
}
