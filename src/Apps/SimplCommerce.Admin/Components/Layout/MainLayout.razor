@inherits LayoutComponentBase

<MudThemeProvider IsDarkMode="_isDark" Theme="AdminTheme.Instance" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        <MudText Typo="Typo.h6" Class="ml-2">SimplCommerce admin</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" Href="/activity-log" />
        <AuthorizeView>
            <Authorized>
                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit">
                    <MudText Class="px-4 py-2" Typo="Typo.caption">@context.User.Identity?.Name</MudText>
                    <MudDivider />
                    <MudMenuItem Href="/logout">Sign out</MudMenuItem>
                </MudMenu>
            </Authorized>
        </AuthorizeView>
        <MudIconButton Icon="@(_isDark ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
            Color="Color.Inherit" OnClick="@(() => _isDark = !_isDark)" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always" Variant="@DrawerVariant.Persistent">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavGroup Title="Catalog" Icon="@Icons.Material.Filled.Inventory2" Expanded="true">
                <MudNavLink Href="/products" Icon="@Icons.Material.Filled.ShoppingBag">Products</MudNavLink>
                <MudNavLink Href="/categories" Icon="@Icons.Material.Filled.Category">Categories</MudNavLink>
                <MudNavLink Href="/brands" Icon="@Icons.Material.Filled.BrandingWatermark">Brands</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Sales" Icon="@Icons.Material.Filled.Receipt">
                <MudNavLink Href="/orders" Icon="@Icons.Material.Filled.Receipt">Orders</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Customers" Icon="@Icons.Material.Filled.People">
                <MudNavLink Href="/users" Icon="@Icons.Material.Filled.Person">Users</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Content" Icon="@Icons.Material.Filled.Article">
                <MudNavLink Href="/reviews" Icon="@Icons.Material.Filled.Reviews">Reviews</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Operations" Icon="@Icons.Material.Filled.Settings">
                <MudNavLink Href="/warehouses" Icon="@Icons.Material.Filled.Warehouse">Warehouses</MudNavLink>
                <MudNavLink Href="/activity-log" Icon="@Icons.Material.Filled.History">Activity log</MudNavLink>
            </MudNavGroup>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-16 px-4">
        <MudContainer MaxWidth="MaxWidth.False" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDark;
}
